{
  "name": "tracedesk",
  "private": true,
  "version": "0.1.14",
  "scripts": {
    "dev": "npm run dev --prefix frontend",
    "build": "npm run build --prefix frontend",
    "test": "cargo test --manifest-path src-tauri/Cargo.toml && npm run build --prefix frontend",
    "tauri": "tauri",
    "tauri:dev": "tauri dev -c src-tauri/tauri.dev.conf.json",
    "tauri:build": "tauri build",
    "tauri:build:open": "tauri build && node scripts/open-installer.mjs"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2"
  }
}
